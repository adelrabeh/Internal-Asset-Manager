# ============================================================
# دارة الملك عبدالعزيز — OCR Platform
# متغيرات البيئة — انسخ هذا الملف إلى .env وعدّل القيم
# ============================================================

# ── قاعدة البيانات ──────────────────────────────────────────
POSTGRES_DB=darah_ocr
POSTGRES_USER=darah
# كلمة مرور قوية لقاعدة البيانات (غيّرها حتماً!)
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_here

# ── أمان الجلسات ────────────────────────────────────────────
# مفتاح عشوائي طويل — أنشئه بـ: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_run_openssl_rand_hex_64_and_paste_here

# ── Gemini AI (مطلوب لمعالجة OCR) ───────────────────────────
# احصل على مفتاحك من: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# نموذج OCR المستخدم:
#   gemini-2.5-flash → مجاني بحدود (الافتراضي — كافٍ لمعظم الوثائق)
#   gemini-2.5-pro   → أدق للمخطوطات المعقدة (مدفوع — يُنصح به لأرشيف دارة الملك عبدالعزيز)
GEMINI_OCR_MODEL=gemini-2.5-flash

# ── المنفذ الخارجي ──────────────────────────────────────────
# المنفذ الذي يستمع عليه Nginx (الواجهة الخارجية)
HTTP_PORT=80
