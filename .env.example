# ============================================================
# دارة الملك عبدالعزيز — OCR Platform
# متغيرات البيئة — انسخ هذا الملف إلى .env وعدّل القيم
# ============================================================

# ── قاعدة البيانات ──────────────────────────────────────────
POSTGRES_DB=darah_ocr
POSTGRES_USER=darah
# كلمة مرور قوية لقاعدة البيانات (غيّرها حتماً!)
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_here

# ── أمان الجلسات ────────────────────────────────────────────
# مفتاح عشوائي طويل — أنشئه بـ: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_run_openssl_rand_hex_64_and_paste_here

# ── Gemini AI (مطلوب لمعالجة OCR) ───────────────────────────
# احصل على مفتاحك من: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# نموذج Gemini المستخدم (فقط عند OCR_ENGINE=gemini):
#   gemini-2.5-flash → مجاني بحدود (الافتراضي)
#   gemini-2.5-pro   → أدق للمخطوطات المعقدة (مدفوع)
GEMINI_OCR_MODEL=gemini-2.5-flash

# ── محرك OCR المستخدم ─────────────────────────────────────────
#   gemini → Gemini Vision (الافتراضي)
#   azure  → Azure OpenAI GPT-4o (أعلى جودة، يتطلب اشتراك Azure)
OCR_ENGINE=gemini

# ── Azure OpenAI (مطلوب فقط عند OCR_ENGINE=azure) ────────────
# من Azure Portal → Resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com
AZURE_OPENAI_KEY=your_azure_openai_key_here
# اسم النموذج المنشور في Azure OpenAI Studio
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# إصدار API (يمكن تركه كما هو)
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── المنفذ الخارجي ──────────────────────────────────────────
# المنفذ الذي يستمع عليه Nginx (الواجهة الخارجية)
HTTP_PORT=80
