# ============================================================
# دارة الملك عبدالعزيز — OCR Platform
# API + Frontend في image واحدة
# ============================================================

FROM node:24-slim AS base
WORKDIR /app

# تثبيت الأدوات النظامية الضرورية
RUN apt-get update && apt-get install -y --no-install-recommends \
    poppler-utils ghostscript imagemagick ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

# تعديل سياسات ImageMagick للسماح بمعالجة PDF
RUN sed -i 's|<policy domain="coder" rights="none" pattern="PDF" />|<policy domain="coder" rights="read|write" pattern="PDF" />|g' \
    /etc/ImageMagick-6/policy.xml 2>/dev/null || true

RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

# ── Dependencies ─────────────────────────────────────────────
FROM base AS deps
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY artifacts/api-server/package.json         ./artifacts/api-server/
COPY artifacts/ocr-dashboard/package.json      ./artifacts/ocr-dashboard/
COPY artifacts/mockup-sandbox/package.json     ./artifacts/mockup-sandbox/
COPY lib/db/package.json                       ./lib/db/
COPY lib/api-spec/package.json                 ./lib/api-spec/
COPY lib/api-zod/package.json                  ./lib/api-zod/
COPY lib/api-client-react/package.json         ./lib/api-client-react/
COPY lib/integrations-gemini-ai/package.json   ./lib/integrations-gemini-ai/

RUN pnpm install --no-frozen-lockfile

# ── Builder ──────────────────────────────────────────────────
FROM deps AS builder
WORKDIR /app

COPY . .

# Build API
RUN pnpm --filter @workspace/api-server run build

# Build Frontend
ENV PORT=3000
ENV BASE_PATH=/
ENV NODE_ENV=production
RUN pnpm --filter @workspace/ocr-dashboard run build

# ── Production ───────────────────────────────────────────────
FROM base AS production
WORKDIR /app

COPY --from=builder /app/artifacts/api-server/dist ./artifacts/api-server/dist
COPY --from=builder /app/artifacts/ocr-dashboard/dist/public ./public

COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/pnpm-workspace.yaml ./pnpm-workspace.yaml
COPY --from=builder /app/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=builder /app/artifacts/api-server/package.json ./artifacts/api-server/
COPY --from=builder /app/lib/db/package.json ./lib/db/
COPY --from=builder /app/lib/api-zod/package.json ./lib/api-zod/
COPY --from=builder /app/lib/api-spec/package.json ./lib/api-spec/
COPY --from=builder /app/lib/api-client-react/package.json ./lib/api-client-react/
COPY --from=builder /app/lib/integrations-gemini-ai/package.json ./lib/integrations-gemini-ai/

#
