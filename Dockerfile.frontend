# ============================================================
# دارة الملك عبدالعزيز — OCR Platform
# حل مشكلة المسارات عبر الاستدعاء المباشر لـ JS
# ============================================================

FROM node:24-slim AS base
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends \
    poppler-utils ghostscript imagemagick ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*
RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

# ── مرحلة التبعات ─────────────────────────────────────────────
FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY artifacts/api-server/package.json         ./artifacts/api-server/
COPY artifacts/ocr-dashboard/package.json      ./artifacts/ocr-dashboard/
COPY lib/db/package.json                       ./lib/db/
COPY lib/api-spec/package.json                 ./lib/api-spec/
COPY lib/api-zod/package.json                  ./lib/api-zod/
COPY lib/api-client-react/package.json         ./lib/api-client-react/
COPY lib/integrations-gemini-ai/package.json   ./lib/integrations-gemini-ai/

RUN pnpm install --no-frozen-lockfile

# ── مرحلة البناء ──────────────────────────────────────────────
FROM deps AS builder
WORKDIR /app
COPY . .
RUN pnpm --filter @workspace/api-server run build
RUN pnpm --filter @workspace/ocr-dashboard run build
# عزل السيرفر
RUN pnpm --filter @workspace/api-server deploy --prod /app/isolated-server

# ── مرحلة الإنتاج النهائية ─────────────────────────────────────
FROM base AS production
WORKDIR /app

# نسخ محتويات السيرفر المعزول إلى الجذر /app
COPY --from=builder /app/isolated-server ./
COPY --from=builder /app/artifacts/api-server/dist ./dist
COPY --from=builder /app/artifacts/ocr-dashboard/dist/public ./public
COPY --from=builder /app/lib/db ./lib/db

# تثبيت المكتبات بشكل مسطح لضمان وجودها في node_modules المحلية
RUN pnpm add drizzle-kit pg connect-pg-simple

# إعداد الصلاحيات والبيانات
RUN mkdir -p /data/sqlite /data/uploads && \
    chmod -R 777 /data/sqlite /data/uploads

ENV NODE_ENV=production
ENV PORT=8080
ENV UPLOADS_DIR=/data/uploads
ENV FRONTEND_PATH=/app/public
ENV DATABASE_URL="file:/data/sqlite/ocr_database.db"

EXPOSE 8080

# --- التغيير الجوهري هنا ---
# بدلاً من مناداة drizzle-kit push، ننادي ملف الـ JS الخاص بها مباشرة 
# لتجنب مشاكل "Module Not Found" في الـ Binaries
CMD node node_modules/drizzle-kit/bin.cjs push && node --enable-source-maps dist/index.mjs
