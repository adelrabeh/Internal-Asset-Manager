# ============================================================
# دارة الملك عبدالعزيز — OCR Platform
# النسخة النهائية باستخدام pnpm deploy
# ============================================================

FROM node:24-slim AS base
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends \
    poppler-utils ghostscript imagemagick ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*
RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

# ── مرحلة التبعات ─────────────────────────────────────────────
FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY artifacts/api-server/package.json         ./artifacts/api-server/
COPY artifacts/ocr-dashboard/package.json      ./artifacts/ocr-dashboard/
COPY lib/db/package.json                       ./lib/db/
COPY lib/api-spec/package.json                 ./lib/api-spec/
COPY lib/api-zod/package.json                  ./lib/api-zod/
COPY lib/api-client-react/package.json         ./lib/api-client-react/
COPY lib/integrations-gemini-ai/package.json   ./lib/integrations-gemini-ai/

RUN pnpm install --no-frozen-lockfile

# ── مرحلة البناء ──────────────────────────────────────────────
FROM deps AS builder
WORKDIR /app
COPY . .
RUN pnpm --filter @workspace/api-server run build
RUN pnpm --filter @workspace/ocr-dashboard run build

# استخراج السيرفر بشكل معزول (هذا يحل مشكلة ERR_MODULE_NOT_FOUND)
RUN pnpm --filter @workspace/api-server deploy --prod /app/isolated-server

# ── مرحلة الإنتاج النهائية ─────────────────────────────────────
FROM base AS production
WORKDIR /app/isolated-server

# 1. نسخ الملفات المعزولة (تحتوي على node_modules حقيقية ومصححة)
COPY --from=builder /app/isolated-server ./

# 2. نسخ الـ Build الخاص بالسيرفر والواجهة
COPY --from=builder /app/artifacts/api-server/dist ./dist
COPY --from=builder /app/artifacts/ocr-dashboard/dist/public ./public
# نسخ كود الـ DB لضمان عمل الهجرة
COPY --from=builder /app/lib/db ./lib/db

# 3. تثبيت يدوي للمكتبات المفقودة داخل المجلد المعزول لضمان الـ ESM
RUN pnpm add connect-pg-simple pg drizzle-kit

# إعداد الصلاحيات والبيئة
RUN mkdir -p /data/uploads && chmod -R 777 /data/uploads ./lib/db
ENV NODE_ENV=production
ENV PORT=8080
ENV UPLOADS_DIR=/data/uploads
ENV FRONTEND_PATH=/app/isolated-server/public

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=5 \
    CMD curl -f http://localhost:8080/api/healthz || exit 1

# التشغيل النهائي
CMD pnpm drizzle-kit push && node --enable-source-maps dist/index.mjs
