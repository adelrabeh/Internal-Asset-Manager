# ============================================================
# دارة الملك عبدالعزيز — OCR Platform
# حل مشكلة الـ Symlinks في بيئة الإنتاج
# ============================================================

FROM node:24-slim AS base
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    poppler-utils ghostscript imagemagick ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

# ── Dependencies ─────────────────────────────────────────────
FROM base AS deps
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY artifacts/api-server/package.json         ./artifacts/api-server/
COPY artifacts/ocr-dashboard/package.json      ./artifacts/ocr-dashboard/
COPY lib/db/package.json                       ./lib/db/
COPY lib/api-spec/package.json                 ./lib/api-spec/
COPY lib/api-zod/package.json                  ./lib/api-zod/
COPY lib/api-client-react/package.json         ./lib/api-client-react/
COPY lib/integrations-gemini-ai/package.json   ./lib/integrations-gemini-ai/

RUN pnpm install --no-frozen-lockfile

# ── Builder ──────────────────────────────────────────────────
FROM deps AS builder
WORKDIR /app

COPY . .
RUN pnpm --filter @workspace/api-server run build
RUN pnpm --filter @workspace/ocr-dashboard run build

# ── Production ───────────────────────────────────────────────
FROM base AS production
WORKDIR /app

# نسخ الملفات المبنية
COPY --from=builder /app/artifacts/api-server/dist ./artifacts/api-server/dist
COPY --from=builder /app/artifacts/ocr-dashboard/dist/public ./public
COPY --from=builder /app/lib/db ./lib/db

# نسخ ملف package.json الخاص بالسيرفر إلى الجزر لتثبيت مكتباته مباشرة
COPY --from=builder /app/artifacts/api-server/package.json ./package.json

# --- الحل الجوهري ---
# استخدام npm بدلاً من pnpm في الإنتاج لتجنب مشاكل Symlinks
# تثبيت المكتبات بشكل Flat داخل /app/node_modules
RUN npm install --omit=dev && \
    npm install connect-pg-simple pg drizzle-kit

# إعداد الصلاحيات
RUN mkdir -p /data/uploads && chmod -R 777 /data/uploads /app/lib/db

ENV NODE_ENV=production
ENV PORT=8080
ENV UPLOADS_DIR=/data/uploads
ENV FRONTEND_PATH=/app/public

EXPOSE 8080

# تشغيل قاعدة البيانات ثم السيرفر
# ملاحظة: استخدمنا npx لضمان تشغيل drizzle-kit من المجلد المحلي
CMD npx drizzle-kit push && node --enable-source-maps artifacts/api-server/dist/index.mjs
