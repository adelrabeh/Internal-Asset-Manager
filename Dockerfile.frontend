# ============================================================
# دارة الملك عبدالعزيز — OCR Platform  |  Frontend (Nginx)
# ============================================================
# Builds the React/Vite dashboard and serves it via Nginx.
# The Nginx config proxies /api/* to the backend API server.
# ============================================================

# ── Stage 1: Build the Vite frontend ────────────────────────
FROM node:24-slim AS builder
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY artifacts/api-server/package.json         ./artifacts/api-server/
COPY artifacts/ocr-dashboard/package.json      ./artifacts/ocr-dashboard/
COPY artifacts/mockup-sandbox/package.json     ./artifacts/mockup-sandbox/
COPY lib/db/package.json                       ./lib/db/
COPY lib/api-spec/package.json                 ./lib/api-spec/
COPY lib/api-zod/package.json                  ./lib/api-zod/
COPY lib/api-client-react/package.json         ./lib/api-client-react/
COPY lib/integrations-gemini-ai/package.json   ./lib/integrations-gemini-ai/
COPY lib/integrations/gemini_ai_integrations/package.json \
     ./lib/integrations/gemini_ai_integrations/

RUN pnpm install --frozen-lockfile

COPY . .

# Build the static dashboard
# PORT is required by vite.config.ts even though it's not used in builds
ENV PORT=3000
ENV BASE_PATH=/
ENV NODE_ENV=production

RUN pnpm --filter @workspace/ocr-dashboard run build

# ── Stage 2: Nginx static server ────────────────────────────
FROM nginx:1.27-alpine AS production

# Copy built frontend
COPY --from=builder /app/artifacts/ocr-dashboard/dist/public /usr/share/nginx/html

# Copy Nginx config
COPY nginx/darah-ocr.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD wget -qO- http://localhost/index.html | grep -q "html" || exit 1

CMD ["nginx", "-g", "daemon off;"]
